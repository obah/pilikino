# Starknet JSON-RPC endpoint
RELAYER_RPC_URL=https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_8/<KEY>

# Stark private key (stark curve scalar), hex or decimal
RELAYER_PRIVATE_KEY=0x...

# Starknet account contract address used by relayer to sign/submit txs
RELAYER_ACCOUNT_ADDRESS=0x...

# Pilikino pool contract address on Starknet
PILIKINO_POOL_ADDRESS=0x...
# Backward-compat fallback name (optional if PILIKINO_POOL_ADDRESS is set)
# FAN_POOL_ADDRESS=0x...

RELAYER_BIND_ADDR=0.0.0.0:8787

# Optional: set ONLY if your proof public_inputs include relayer and fee words.
# For the current Pilikino circuit (first 6 publics are root/nullifier/addr/data_hash/amount/new_commitment),
# leave these unset unless your SDK/relayer flow appends extra public inputs.
# RELAYER_PUBLIC_INPUT_RELAYER_INDEX=
# RELAYER_PUBLIC_INPUT_FEE_INDEX=

RELAYER_BATCH_SIZE=3
RELAYER_BATCH_MAX_WAIT_SECS=15
RELAYER_RETRY_MAX_ATTEMPTS=5
RELAYER_RETRY_BASE_DELAY_MS=500
RELAYER_MEMPOOL_PATH=./data/mempool.json
